
@model UserAuth.ModelView.ResetPasswordModelView

@{
    ViewData["Title"] = "Reset Password";
}

<div class="container py-5">
    <div class="row justify-content-center align-items-center min-vh-100">

        <div class="col-lg-6 col-md-8 col-sm-11">

            <div class="card border-0 shadow-lg rounded-4">

                <div class="card-body p-5">

                    <div class="text-center mb-4">

                        <h2 class="fw-bold text-primary">
                            Reset Your Password
                        </h2>

                        <p class="text-muted mb-0">
                            Create a new password for your account. Choose a strong password to keep your account secure.
                        </p>

                    </div>

                    <form asp-action="ResetPassword"
                          asp-controller="User"
                          method="post">

                        <div asp-validation-summary="ModelOnly"
                             class="alert alert-danger">
                        </div>

                        <!-- Hidden Fields -->
                        <input asp-for="Token" type="hidden" />
                        <input asp-for="Email" type="hidden" />

                        <div class="mb-3">
                            <label asp-for="Password"
                                   class="form-label fw-semibold"></label>

                            <input asp-for="Password"
                                   type="password"
                                   class="form-control form-control-lg"
                                   placeholder="Enter your new password" />

                            <span asp-validation-for="Password"
                                  class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmPassword"
                                   class="form-label fw-semibold"></label>

                            <input asp-for="ConfirmPassword"
                                   type="password"
                                   class="form-control form-control-lg"
                                   placeholder="Confirm your new password" />

                            <span asp-validation-for="ConfirmPassword"
                                  class="text-danger small"></span>
                        </div>

                        <div class="d-grid mb-3">
                            <button type="submit"
                                    class="btn btn-primary btn-lg rounded-3">
                                Reset Password
                            </button>
                        </div>

                        <hr />

                        <div class="text-center">
                            <p class="mb-3">
                                Remember your password?
                                <a asp-controller="User"
                                   asp-action="Login"
                                   class="text-decoration-none fw-semibold">
                                    Login
                                </a>
                            </p>

                            <a asp-controller="Home"
                               asp-action="Index"
                               class="btn btn-outline-secondary rounded-3">
                                ← Back to Home
                            </a>
                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

