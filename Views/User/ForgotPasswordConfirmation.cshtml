
@{
    ViewData["Title"] = "Forgot Password Confirmation";
}

<div class="container py-5">
    <div class="row justify-content-center align-items-center min-vh-100">

        <div class="col-lg-7 col-md-9 col-sm-11">

            <div class="card border-0 shadow-lg rounded-4">

                <div class="card-body p-5 text-center">

                    <div class="mb-4">
                        <div class="display-1 text-success">
                            <i class="bi bi-envelope-check-fill"></i>
                        </div>

                        <h2 class="fw-bold text-primary mt-3">
                            Check Your Email
                        </h2>

                        <p class="text-muted mb-0">
                            If the email address you entered is associated with an account,
                            we've sent a password reset link to your inbox.
                        </p>
                    </div>

                    <div class="alert alert-light border rounded-3">

                        <p class="mb-2">
                            Please check your <strong>Inbox</strong>.
                        </p>

                        <p class="mb-0">
                            If you don't receive the email within a few minutes,
                            please check your <strong>Spam</strong> or <strong>Junk</strong> folder,
                            or request another reset link.
                        </p>

                    </div>

                    <div class="d-grid gap-3 mt-4">

                        <a asp-controller="User"
                           asp-action="ForgotPassword"
                           class="btn btn-outline-primary btn-lg rounded-3">
                            Send Another Reset Link
                        </a>

                        <a asp-controller="User"
                           asp-action="Login"
                           class="btn btn-primary btn-lg rounded-3">
                            Return to Login
                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>
</div>

