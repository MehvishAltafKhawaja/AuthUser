@model UserAuth.ModelView.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="container my-5">
      <div class="row justify-content-center">
          <div class="col-sm-12 col-md-12 col-lg-6">
              <div>
                  <div class="bg-primary text-white">
                      <h4 class="mb-0 text-center">Reset Your Password</h4>
                  </div>
                  <div>
                      <p class="text-muted text-center mb-4">
                        Enter Your registered email address below and we will send you a link to reset your password.
                      </p>
                      <form method="post" asp-action="ForgotPassword" asp-controller="User">
                          <div asp-validation-summary="All" class="alert alert-danger" role="alert" style="display:none;"></div>

                          <div class="form-group mb-3">
                              <label asp-for="Email" class="form-label fw-bold">Email Address</label>
                              <input asp-for="Email" class="form-control" placeholder="Please Enter Your Email"/>
                              <span asp-validation-for="Email" class="text-danger"></span>
                          </div>

                          <div class="d-grid">
                              <button type="submit" class="btn btn-primary btn-lg">
                                  Send Reset Link
                              </button>
                          </div>
                      </form>
                  </div>
                  <div class="card-footer text-center">
                      <p class="mb-0">
                          <a asp-controller="User" asp-action="Login" class="text-primary text-decoration-none">
                               Back To Login
                          </a>
                      </p>
                  </div>
              </div>
          </div>
      </div>
</div>